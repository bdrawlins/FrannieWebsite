# Browser-public website config. These values are generated into
# site-config.js, so they are not secrets once deployed.
FRANNIE_FORMSPARK_FORM_URL=https://submit-form.com/your-form-id
FRANNIE_PUBLIC_CALENDAR_ID=your-calendar-id@group.calendar.google.com
FRANNIE_TIME_ZONE=America/Los_Angeles
FRANNIE_CONTACT_EMAIL=frannietheclown1@gmail.com
FRANNIE_CONTACT_PHONE_DISPLAY="(619) 933-7737"
FRANNIE_CONTACT_PHONE_TEL=+16199337737
FRANNIE_FACEBOOK_URL=https://www.facebook.com/p/Frannie-the-Clown-100076459472472/
FRANNIE_YELP_URL=https://www.yelp.com/biz/frannie-the-clown-san-diego
# Public endpoint used by the booking form to load unavailable dates.
FRANNIE_APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/deployment-id/exec
# Optional Formspark spam protection. This is the Botpoison public key only.
# Keep the Botpoison secret key in Formspark settings.
FRANNIE_BOTPOISON_PUBLIC_KEY=

# Google Apps Script config. Add these as Script Properties in Apps Script;
# they are listed here so the full deployment config stays in one place.
FRANNIE_APPS_SCRIPT_BOOKING_CALENDAR_ID=your-calendar-id@group.calendar.google.com
FRANNIE_APPS_SCRIPT_BLOCKING_CALENDAR_IDS=your-calendar-id@group.calendar.google.com
FRANNIE_APPS_SCRIPT_NOTIFY_EMAIL=frannietheclown1@gmail.com
FRANNIE_APPS_SCRIPT_TIME_ZONE=America/Los_Angeles
# Also set this as WEB_APP_URL in Apps Script Script Properties if approval
# email links need an explicit deployment URL.
# Optional private key for the Apps Script phone-booking helper URL.
FRANNIE_APPS_SCRIPT_MANUAL_BOOKING_KEY=
# Optional. Leave blank unless Frannie has a private details calendar.
FRANNIE_APPS_SCRIPT_PRIVATE_BOOKING_DETAILS_CALENDAR_ID=
# Put this value in Apps Script as WEBHOOK_SECRET, then append it to the
# Formspark webhook URL as ?booking_key=... Do not add it to GitHub Pages vars.
FRANNIE_APPS_SCRIPT_WEBHOOK_SECRET=
